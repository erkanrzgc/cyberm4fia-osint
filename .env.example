# cyberm4fia-osint — sample environment file
# copy to .env and `source .env` (or use `python-dotenv`) before running.

# ── LLM backend ──────────────────────────────────────────────────────────
# The HttpBackend is OpenAI-compatible. Works with LM Studio, Ollama, vLLM,
# llama.cpp server, OpenAI, NVIDIA NIM, Groq, Together.ai, etc.
CYBERM4FIA_LLM_BACKEND=http

# ── NVIDIA NIM (integrate.api.nvidia.com) ────────────────────────────────
CYBERM4FIA_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
CYBERM4FIA_LLM_API_KEY=nvapi-REPLACE_ME
# Pick one:
#   meta/llama-3.3-70b-instruct              — balanced default
#   nvidia/llama-3.1-nemotron-70b-instruct   — stronger reasoning
#   meta/llama-3.1-405b-instruct             — largest, slower
#   deepseek-ai/deepseek-r1                  — reasoning / chain-of-thought
CYBERM4FIA_LLM_MODEL=meta/llama-3.3-70b-instruct
CYBERM4FIA_LLM_MAX_TOKENS=1024
CYBERM4FIA_LLM_TEMPERATURE=0.2
CYBERM4FIA_LLM_TIMEOUT=120

# ── LM Studio (legacy, localhost) ────────────────────────────────────────
# CYBERM4FIA_LLM_URL=http://localhost:1234/v1/chat/completions
# CYBERM4FIA_LLM_API_KEY=lm-studio
# CYBERM4FIA_LLM_MODEL=

# ── Optional API keys for OSINT modules ──────────────────────────────────
# HIBP_API_KEY=
# NUMVERIFY_API_KEY=
# GITHUB_TOKEN=           # 5000/hr vs 60/hr anon for github_org recon
# SHODAN_API_KEY=
# CENSYS_API_ID=
# CENSYS_API_SECRET=
