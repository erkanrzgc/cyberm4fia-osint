# cyberm4fia-osint — sample environment file
# Copy to .env, fill in keys you need. Every key is optional except the LLM
# block if you want --ai or SE-arsenal pretext drafts. Modules silently skip
# when their key is missing.

# ── LLM (NVIDIA NIM by default) ──────────────────────────────────────────
# Free tier: ~1000 req/month. https://build.nvidia.com
CYBERM4FIA_LLM_BACKEND=http
CYBERM4FIA_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
CYBERM4FIA_LLM_API_KEY=nvapi-REPLACE_ME
CYBERM4FIA_LLM_MODEL=meta/llama-3.3-70b-instruct
CYBERM4FIA_LLM_MAX_TOKENS=1024
CYBERM4FIA_LLM_TEMPERATURE=0.2
CYBERM4FIA_LLM_TIMEOUT=120
# Other NIM models worth trying (set CYBERM4FIA_LLM_MODEL to one of these):
#   nvidia/llama-3.1-nemotron-70b-instruct   — best red-team reasoning
#   deepseek-ai/deepseek-r1                  — chain-of-thought
#   meta/llama-3.1-405b-instruct             — flagship, slow + costly
#   meta/llama-3.1-8b-instruct               — fast/cheap for bulk pretext
# To use OpenAI / Groq / Ollama instead, override URL + KEY + MODEL.

# ── OSINT module API keys ────────────────────────────────────────────────
# HIBP — paid breach lookup ($3.95/mo). https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=
# NumVerify — phone enrichment, free 250/mo. https://numverify.com
# NUMVERIFY_API_KEY=
# GitHub — recommended (60→5000 req/hr). https://github.com/settings/tokens
# GITHUB_TOKEN=

# Passive recon (host/cert/leak indexes — all skip when missing):
# SHODAN_API_KEY=
# CENSYS_API_ID=
# CENSYS_API_SECRET=
# ZOOMEYE_API_KEY=
# FOFA_EMAIL=
# FOFA_KEY=
# CRIMINALIP_API_KEY=
# SERPAPI_API_KEY=                  # google_dork uses DDG fallback when unset
# WIGLE_API_NAME=                   # both halves required for BSSID lookup
# WIGLE_API_TOKEN=
# OPENCORPORATES_API_TOKEN=         # optional; lifts free-tier rate limit
# INTELX_API_KEY=                   # required for paste/leak/dark-web index

# Other:
# ETHERSCAN_API_KEY=                # ETH balance + tx for --crypto
# TINEYE_API_KEY=                   # Yandex fallback runs without a key
# IG_SESSION_ID=                    # Toutatis rich Instagram mode
# OSINT_AUTH_SECRET=                # only when --serve runs with --auth
# GOPHISH_API_KEY=                  # SE arsenal --se-gophish-key fallback
