# cyberm4fia-osint — sample environment file
# Usage:
#   cp .env.example .env
#   # edit with real keys
#   set -a && source .env && set +a      # exports every KEY=VAL to the process
#   python main.py alice --full
#
# Everything here is optional except the LLM block if you want AI analysis
# (ai_report + SE arsenal pretext drafts). The scanner itself runs without
# any of these keys — they only unlock specific modules.


# ══════════════════════════════════════════════════════════════════════════
# LLM — NVIDIA NIM  (PRIMARY)
# ══════════════════════════════════════════════════════════════════════════
# Get a free API key at https://build.nvidia.com
# Free tier gives ~1000 requests/month across all models below. Billed only
# after you upgrade. The endpoint is OpenAI-compatible, so the HttpBackend
# in core/analysis/llm.py talks to it with zero code changes.

CYBERM4FIA_LLM_BACKEND=http
CYBERM4FIA_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
CYBERM4FIA_LLM_API_KEY=nvapi-REPLACE_ME

# ── Model choice — matters for red-team work ─────────────────────────────
# Balanced default for ai_report + pretext drafting:
CYBERM4FIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# Alternatives (uncomment one instead of the line above):
#
# Red-team reasoning (pretext, linkage analysis — recommended for SE arsenal):
#   CYBERM4FIA_LLM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
#
# Chain-of-thought reasoning (slow but best for multi-hop OSINT inference):
#   CYBERM4FIA_LLM_MODEL=deepseek-ai/deepseek-r1
#
# Largest flagship (most expensive tokens; use when depth beats latency):
#   CYBERM4FIA_LLM_MODEL=meta/llama-3.1-405b-instruct
#
# Fast + cheap (bulk pretext generation across many targets):
#   CYBERM4FIA_LLM_MODEL=meta/llama-3.1-8b-instruct
#
# Uncensored-ish (NVIDIA's own fine-tune, useful when safety filters reject
# legitimate red-team scenarios; still refuses hard-malicious prompts):
#   CYBERM4FIA_LLM_MODEL=nvidia/nemotron-4-340b-instruct

CYBERM4FIA_LLM_MAX_TOKENS=1024
CYBERM4FIA_LLM_TEMPERATURE=0.2
# Pretext generation uses 0.4 by default — set higher here only if you want
# ai_report itself to be more creative (not usually what you want).
CYBERM4FIA_LLM_TIMEOUT=120


# ══════════════════════════════════════════════════════════════════════════
# LLM — other OpenAI-compatible backends (fallbacks, not used by default)
# ══════════════════════════════════════════════════════════════════════════
# To use any of these, replace the three NVIDIA lines above with the block
# you want. Everything else stays the same.

# ── LM Studio (local, no cost, no rate limit) ─────────────────────────────
# CYBERM4FIA_LLM_URL=http://localhost:1234/v1/chat/completions
# CYBERM4FIA_LLM_API_KEY=lm-studio
# CYBERM4FIA_LLM_MODEL=

# ── Ollama (local) ────────────────────────────────────────────────────────
# CYBERM4FIA_LLM_URL=http://localhost:11434/v1/chat/completions
# CYBERM4FIA_LLM_API_KEY=ollama
# CYBERM4FIA_LLM_MODEL=llama3.1:70b

# ── OpenAI ────────────────────────────────────────────────────────────────
# CYBERM4FIA_LLM_URL=https://api.openai.com/v1/chat/completions
# CYBERM4FIA_LLM_API_KEY=sk-...
# CYBERM4FIA_LLM_MODEL=gpt-4o-mini

# ── Groq (fastest, has free tier) ─────────────────────────────────────────
# CYBERM4FIA_LLM_URL=https://api.groq.com/openai/v1/chat/completions
# CYBERM4FIA_LLM_API_KEY=gsk_...
# CYBERM4FIA_LLM_MODEL=llama-3.3-70b-versatile


# ══════════════════════════════════════════════════════════════════════════
# OSINT module API keys  (all optional — modules skip cleanly without them)
# ══════════════════════════════════════════════════════════════════════════

# ── Breach check ──────────────────────────────────────────────────────────
# HaveIBeenPwned — paid, $3.95/mo, needed for email breach lookups.
# Get at https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=

# ── Phone enrichment ──────────────────────────────────────────────────────
# NumVerify — free 250/mo, carrier + line-type + country detail.
# Get at https://numverify.com
# NUMVERIFY_API_KEY=

# ── GitHub (STRONGLY RECOMMENDED for red-team recon) ──────────────────────
# Without a token: 60 requests/hour. With: 5000/hour.
# github_org.scan_org hammers the repo + commits endpoints — 60/hr is unusable.
# Create a classic PAT with NO scopes (public_repo is enough) at
# https://github.com/settings/tokens
# GITHUB_TOKEN=

# ── Passive recon sources (all free, need a signup) ───────────────────────
# Shodan — host/service intel. https://account.shodan.io
# SHODAN_API_KEY=
# Censys — cert + host intel. https://search.censys.io/account/api
# CENSYS_API_ID=
# CENSYS_API_SECRET=
# ZoomEye — Chinese Shodan analogue, often sees hosts Shodan misses.
# ZOOMEYE_API_KEY=
# FOFA — Chinese host/cert search. Email + key together.
# FOFA_EMAIL=
# FOFA_KEY=
# Criminal IP — host index with attack-surface scoring + vuln/honeypot counts.
# Free tier covers casual recon. https://www.criminalip.io/mypage/api
# CRIMINALIP_API_KEY=
# Google dorking — SerpAPI when set; otherwise falls back to DuckDuckGo HTML
# scraping (keyless, lower quality). https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=
# Wigle — BSSID/SSID → physical location lookup. Both halves required.
# Free tier ~100 queries/day. https://wigle.net/account
# WIGLE_API_NAME=
# WIGLE_API_TOKEN=
# OpenCorporates — corporate registry index, officers/directors per
# company. Token is OPTIONAL: free tier (~500 reqs/month) works
# anonymously, the token just lifts the ceiling.
# https://opencorporates.com/api_accounts/new
# OPENCORPORATES_API_TOKEN=
# Intelligence X — paste / leak / dark-web index. Required key.
# Free tier has limited monthly credits. https://intelx.io/account?tab=developer
# INTELX_API_KEY=

# ── Blockchain (for --crypto) ─────────────────────────────────────────────
# Etherscan — ETH balance + tx history. https://etherscan.io/myapikey
# ETHERSCAN_API_KEY=

# ── Reverse image ─────────────────────────────────────────────────────────
# TinEye — commercial, paid per-lookup. Yandex fallback needs no key.
# TINEYE_API_KEY=

# ── Instagram (Toutatis rich mode) ────────────────────────────────────────
# Paste your own sessionid cookie from a logged-in browser. Without it,
# Toutatis falls back to anonymous lookup (less data).
# IG_SESSION_ID=

# ── Web API auth (only if you run --serve with --auth) ────────────────────
# Random 32+ byte hex. Generate with: python -c 'import secrets;print(secrets.token_hex(32))'
# OSINT_AUTH_SECRET=


# ══════════════════════════════════════════════════════════════════════════
# SE Arsenal  (red-team CLI --se-arsenal, optional GoPhish integration)
# ══════════════════════════════════════════════════════════════════════════
# Fallback value for --se-gophish-key. URL still has to be passed via CLI.
# GOPHISH_API_KEY=
